# Get your API key from https://portal.jup.ag/
JUPITER_API_KEY=your_jupiter_api_key_here

# Optional: Birdeye API key for arbitrary Solana token OHLCV charts
# Free tier: https://birdeye.so/  (100k req/month)
# If omitted, charts fall back to CoinGecko (major tokens only: SOL, BTC, ETH, JUP, USDC)
# BIRDEYE_API_KEY=your_birdeye_api_key_here

# Optional: GeckoTerminal / CoinGecko API key (alternative to Birdeye)
# Free tier: https://www.coingecko.com/en/developers/dashboard
# GECKOTERMINAL_API_KEY=your_geckoterminal_api_key_here

# Backend
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Frontend (Vite)
VITE_API_BASE=http://localhost:4000
VITE_RPC_URL=https://api.mainnet-beta.solana.com
VITE_CLUSTER=mainnet-beta
